# Copy to .env locally (never commit .env). Set the same keys in Northflank secrets.

EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Production Browse + OAuth (default). For sandbox: https://api.sandbox.ebay.com
EBAY_API_ROOT=https://api.ebay.com

# Browse API marketplace (US)
EBAY_MARKETPLACE_ID=EBAY_US

# Must match the Notification Endpoint URL in eBay developer portal (Alerts & Notifications) exactly, including path and trailing slash policy.
EBAY_MAD_PUBLIC_URL=https://your-service.example.com/webhooks/ebay-marketplace-account-deletion

# 32–80 chars: alphanumeric, underscore, hyphen only (eBay rule). Same value pasted into the portal Verification token field.
EBAY_MAD_VERIFICATION_TOKEN=

# Server bind (Northflank sets PORT)
PORT=8080
